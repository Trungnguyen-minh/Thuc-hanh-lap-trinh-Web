@model Website.Models.Product

@{
    ViewData["Title"] = Model?.Name;
}

<div class="max-w-7xl mx-auto px-4 py-10">
    <div class="grid md:grid-cols-2 gap-12">
        <!-- Hình ảnh -->
        <div>
            <img src="@Model.ImageUrl" alt="@Model.Name"
                 class="w-full rounded-2xl shadow-lg">
        </div>

        <!-- Thông tin -->
        <div>
            <h1 class="text-4xl font-bold mb-4">@Model.Name</h1>
            <p class="text-3xl font-semibold text-indigo-600 mb-6">
                @string.Format("{0:N0} ₫", Model.Price)
            </p>

            <div class="prose mb-8">
                <p>@Model.Description</p>
            </div>

            <button onclick="addToCart(@Model.Id, '@Model.Name', @Model.Price)"
                    class="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-4 rounded-2xl text-xl font-semibold transition">
                <i class="fas fa-cart-plus"></i> Thêm vào giỏ hàng
            </button>
        </div>
    </div>
</div>