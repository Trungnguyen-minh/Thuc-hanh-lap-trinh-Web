@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero -->
<div class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white py-24">
    <div class="max-w-7xl mx-auto px-4 text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6">Chào mừng đến với ShopVN</h1>
        <p class="text-xl md:text-2xl mb-8">Sản phẩm chất lượng - Giá tốt nhất - Giao hàng nhanh</p>
        <a href="/Products"
           class="inline-block bg-white text-indigo-600 px-10 py-4 rounded-xl text-lg font-semibold hover:bg-gray-100 transition">
            Mua sắm ngay
        </a>
    </div>
</div>

<!-- Danh mục -->
<div class="max-w-7xl mx-auto px-4 py-12">
    <h2 class="text-3xl font-bold text-center mb-10">Danh mục sản phẩm</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-2xl shadow hover:shadow-xl transition text-center">Điện thoại</div>
        <div class="bg-white p-6 rounded-2xl shadow hover:shadow-xl transition text-center">Laptop</div>
        <div class="bg-white p-6 rounded-2xl shadow hover:shadow-xl transition text-center">Phụ kiện</div>
        <div class="bg-white p-6 rounded-2xl shadow hover:shadow-xl transition text-center">Thời trang</div>
    </div>
</div>

<!-- Sản phẩm nổi bật -->
<div class="max-w-7xl mx-auto px-4 py-12 bg-white">
    <h2 class="text-3xl font-bold mb-8">Sản phẩm nổi bật</h2>
    <div id="featured-products" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        <!-- Sẽ được load bằng JS hoặc Partial View -->
    </div>
</div>